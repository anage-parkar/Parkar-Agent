# Copy to `.env` and adjust as needed. All values have sensible defaults in config.py.

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2:latest
EMBED_MODEL=nomic-embed-text:latest
LLM_TEMPERATURE=0.2
LLM_NUM_CTX=4096
REQUEST_TIMEOUT=120

# --- Vector store ---
COLLECTION_NAME=parkar_knowledge

# --- Chunking ---
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# --- Retrieval ---
TOP_K=5
MIN_SIMILARITY=0.25

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=*
ASSISTANT_NAME=Parkar Assistant
